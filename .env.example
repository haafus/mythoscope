# All variables are optional — defaults work out of the box.
# Prefix: MYTHO_

# --- Paths (relative to project root or absolute) ---
# MYTHO_CORPUS_DIR=corpus
# MYTHO_CORPUS_CHUNKED_DIR=corpus_chunked
# MYTHO_CHROMA_DIR=chroma_db
# MYTHO_CACHE_DIR=cache
# MYTHO_ANALYSIS_DIR=analysis
# MYTHO_LOGS_DIR=logs
# MYTHO_GRAPHS_DIR=graphs

# --- Embeddings ---
# MYTHO_DEFAULT_EMBEDDING_MODEL=BAAI/bge-m3
# MYTHO_DEFAULT_CHUNKING=paragraph

# --- LLM (for graph generation) ---
# MYTHO_OPENAI_API_KEY=sk-...
# MYTHO_OPENAI_BASE_URL=https://api.openai.com/v1
# MYTHO_LLM_MODEL_NAME=gpt-4o-mini

# --- Logging ---
# MYTHO_LOG_LEVEL=INFO
